# -------------------------------------------------------
# main/ — old drill_4_4 leftover (full copy, 5022 files, 116MB)
# Created when the directory was renamed; serves no purpose.
main/drill_4_4/

# Runtime-generated by p4run — not source, changes every boot
main/topology.json

# P4 compiled output
main/p4src/*.json

# Live controller runtime outputs
main/live_telemetry.csv
main/live_telemetry*.png
main/confusion_matrix.png

# Generated research outputs — datasets, validation runs, plots (kept local, not in repo)
main/research_results/data/datasets/
main/research_results/data/validation/
main/research_results/plots/

# Hyperparameter tuning trial logs + backups (generated, kept local)
main/tuning_results/
main/backups/

# Prototype data artifacts in bruh/ (the .py code stays tracked, the data does not)
main/bruh/*.csv
main/bruh/*-dump.txt

# Temporary analysis slices
main/temp_x_*.csv

# Raw 10s telemetry CSVs — generated by dataset_builder.py (4887 files, 38MB)
main/raw_telemetry/

# Dataset pipeline intermediates (authoritative copies live in research_results/)
main/training_dataset_ecdf.csv
main/training_dataset_temporal.csv

# Generated reports / docs (not source)
main/final_summary.txt
main/DETAILED_COLUMN_REFERENCE.txt
main/analyze.sh
main/detailed_analysis.sh

# Generated at startup by start_env.sh / all_controller.py --summary
main/.grouping_summary.txt


